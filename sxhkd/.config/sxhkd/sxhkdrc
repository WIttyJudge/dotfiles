/* Some environment variable are located in the .zpofile file. E.g. $TERMINAL */

/* start terminal */
super + Return
    $TERMINAL

/* start dmenu (a program launcher) */
super + p
    dmenu_run -c -l 10

super + shift + r 
      $TERMINAL -e htop

super + shift + w 
      $TERMINAL -n calcurse -e calcurse

/* Audio volumes */
super + {XF86AudioMute, XF86AudioLowerVolume, XF86AudioRaiseVolume} 
    amixer -q -D pulse set Master {toggle, 10%-, 10%+}; pkill -RTMIN+10 dwmblocks

/* Brightness volumes */
super + {XF86MonBrightnessDown, XF86MonBrightnessUp} 
    sudo light {-U 10, -A 10}

/* Ride side buttons */
KP_Add 
    toggle-microphone --toggle; pkill -RTMIN+20 dwmblocks

/* screenshoter */
Print
    flameshot gui

/* Custom commands */
super + Delete 
    dmenu-script-select

