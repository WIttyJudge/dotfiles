/* Some environment variable are located in the .zpofile file. E.g. $TERMINAL */

/* start terminal */
super + Return
        $TERMINAL

/* start dmenu (a program launcher) */
super + p
        dmenu_run -c -l 10

/* Function Button */

super + {F1, F2, F3} 
        amixer -q -D pulse set Master {toggle, 5%-, 5%+}

/* Ride side buttons */

/* scrinshoter */
Print
    flameshot gui

super + Delete 
        dmenu-script-select
