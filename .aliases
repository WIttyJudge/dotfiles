# sudo not required for some system commands
for x in mount umount sv pacman ; do
	alias $x="sudo $x"
done

# useful
alias \
  s="sudo " \
  p="sudo pacman " \
	cp="cp -iv" \
	mv="mv -iv" \
  ping="ping -c 3 8.8.8.8" \
  e="$EDITOR" \

# for testing
alias \
  t-micro="arecord -vv -f dat /dev/null" \
  t-sound="speaker-test -c2 -t wav" \

# fast cd
alias \
  ..="cd .." \

# commands
alias dotfiles="cd ~/dotfiles && $EDITOR"

# rewrite standard commands
alias \
  cat="bat" \
  rip="rip --graveyard ~/.local/share/Trash " \

alias ls="exa -l --group-directories-first --icons" # doesn't show hidden files
alias ls.="exa -dl .* --icons" # shows only hidden files
alias lst="exa -l --sort newest --icons" # sort output by newest file
alias la="exa -la --group-directories-first --icons"  # all files and dirs

# git
alias \
  g="git " \
  gs="git status" \
  ga="git add" \
  gc="git commit" \
  gp="git push" \

# docker
alias \
  d="sudo docker " \
  dc="sudo docker-compose " \
  drmc="sudo docker rm $(sudo docker ps -aq)" \

