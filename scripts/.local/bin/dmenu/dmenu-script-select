#!/bin/sh

commands=(
  '< Exit'
  '---'
  '1 [ System ]'
  '2 [ Reloader ]'
  '---'
  '3 [ rofi-pass ]'
  '4 [ bookmarks ]'
  '---'
  'dotfiles'
  'suckess-tools'
)

scripts_folder="$HOME/.local/bin/dmenu"

# choice="$(printf '%b\n' "${commands[@]}" | rofi -dmenu -i bmenu -p "Select command > ")"
choice="$(printf '%b\n' "${commands[@]}" | dmenu -c -l 10 -h 30 )"

case "$choice" in
  "1 [ System ]")
    system ;;
  "2 [ Reloader ]")
    dmenu-reloader ;;
  "3 [ rofi-pass ]")
    rofi-pass ;;
  "4 [ bookmarks ]")
    open-bookmarks ;;
  "dotfiles")
    $TERMINAL -e sh -c 'tmux-sessionizer /home/wittyjudge/dotfiles' ;;
  "suckess-tools")
    $TERMINAL -e sh -c 'tmux-sessionizer /home/wittyjudge/suckless-tools' ;;
  '< Exit') exit ;;
  *) exit ;;
esac
