#!/bin/sh

files=(
  # i3wm
  .Xresources
  sxhkd
  .zshrc
)

choice="$(printf '%s\n' "${files[@]}" | dmenu -p "What to reload > ")"

notifier() {
  notify-send "$1 successfully reloaded."
}

case "$choice" in
  # i3wm)
  #   i3-msg restart && notifier "i3wm" ;;
  .Xresources)
    xrdb ~/.Xresources && notifier ".Xresources" ;;
  .zshrc)
    source ~/.zshrc && notifier ".zshrc" ;;
  sxhkd)
    pkill sxhkd; sxhkd &&
    notifier "sxhkd" ;;
  *) exit ;;
esac
