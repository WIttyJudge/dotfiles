#!/bin/sh

# my custom script
command="toggle-microphone"

if ! command -v $command > /dev/null; then
  exit_code="$?"
  msg="$command error"

  notify-send -u critical "'$command' is not available."
  printf " %s \\n" "$msg"

  exit $exit_code
fi

case $BLOCK_BUTTON in
	1) toggle-microphone --toggle ;;
esac

mic_muted="$($command --get-status)"

if [ "$mic_muted" = "muted" ]; then
  icon="🔇"
else
  icon="🎙️"
fi

printf " %s \\n" "$icon"
