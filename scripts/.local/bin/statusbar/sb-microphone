#!/bin/sh

# my custom script
command="toggle-microphone"

ifcommand $command || exit

case $BLOCK_BUTTON in
	1) toggle-microphone --toggle ;;
esac

mic_muted="$($command --get-status)"

if [ "$mic_muted" = "muted" ]; then
  icon="🔇"
  paplay ~/discordmute.vaw
else
  icon="🎙️"
fi

printf " %s \\n" "$icon"
