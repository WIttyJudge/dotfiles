#!/bin/sh

command="pamixer"

if ! command -v pamixer > /dev/null; then
  exit_code="$?"
  msg="$command error"

  notify-send "'$command' is not available."
  printf " %s \\n" "$msg"

  exit $exit_code
fi

$command --list-sources \
  | grep input \
  | awk '{print $1}' \
  | while read -r index; do

    mic_muted="$($command --source "$index" --get-mute)"

    if [ "$mic_muted" = "true" ]; then
      $command --source "$index" -u
      # notify-send "Microphone unmuted"
      icon="🎙️"

      printf " %s \\n" "$icon"
    else
      $command --source "$index" -m
      # notify-send "Microphone muted"
      icon="🔇"

      printf " %s \\n" "$icon"
    fi
done

