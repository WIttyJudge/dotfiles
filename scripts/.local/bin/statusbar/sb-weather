#!/bin/bash

command="curl"

if ! command -v $command > /dev/null 2>&1; then
  exit_code="$?"
  msg="$command error"

  notify-send -u critical "'$command' is not available."
  printf " %s \\n" "$msg"

  exit $exit_code
fi

icon="⛅"

case $BLOCK_BUTTON in
  1) 
    weather=$($command -s wttr.in/Moscow?format="%t+%h") 
    notify-send 'Weather'  "$weather" 
    ;;

esac


printf " %s\\n" "$icon "

