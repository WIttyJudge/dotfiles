# Source: https://gitlab.com/dwt1/shell-color-scripts/-/blob/master/colorscripts/crunch
crunch() {

cat << EOF

 ${reset}${redf}  ‚Ėą‚Ėą  ‚Ėą‚Ėą   ${reset}${greenf}   ‚Ėą‚Ėą  ‚Ėą‚Ėą   ${reset}${yellowf}   ‚Ėą‚Ėą  ‚Ėą‚Ėą   ${reset}${bluef}   ‚Ėą‚Ėą  ‚Ėą‚Ėą   ${reset}${purplef}   ‚Ėą‚Ėą  ‚Ėą‚Ėą   ${reset}${cyanf}   ‚Ėą‚Ėą  ‚Ėą‚Ėą   ${reset}
