  ${redf}‚Ėą‚Ėą‚Ėą‚Ėą${boldon}${redfbright}‚Ėą${reset}${redf}‚Ėą‚Ėą‚Ėą‚Ėą${reset}   ${blackf}|${reset}   ${greenf}‚Ėą‚Ėą‚Ėą‚Ėą${boldon}${greenfbright}‚Ėą${reset}${greenf}‚Ėą‚Ėą‚Ėą‚Ėą${reset}   ${blackf}|${reset}   ${yellowf}‚Ėą‚Ėą‚Ėą‚Ėą${boldon}${yellowfbright}‚Ėą${reset}${yellowf}‚Ėą‚Ėą‚Ėą‚Ėą${reset}   ${blackf}|${reset}   ${bluef}‚Ėą‚Ėą‚Ėą‚Ėą${boldon}${bluefbright}‚Ėą${reset}${bluef}‚Ėą‚Ėą‚Ėą‚Ėą${reset}   ${blackf}|${reset}   ${purplef}‚Ėą‚Ėą‚Ėą‚Ėą${boldon}${purplefbright}‚Ėą${reset}${purplef}‚Ėą‚Ėą‚Ėą‚Ėą${reset}   ${blackf}|${reset}   ${cyanf}‚Ėą‚Ėą‚Ėą‚Ėą${boldon}${cyanfbright}‚Ėą${reset}${cyanf}‚Ėą‚Ėą‚Ėą‚Ėą${reset}
