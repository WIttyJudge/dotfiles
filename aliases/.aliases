alias s="sudo "

# commands
alias dotfiles="cd ~/dotfiles && $EDITOR"

# git
alias g="git "
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"

# directory
alias cdd="cd ~/Desktop "
alias ls="exa"
alias ll="exa -la"
alias ll.='exa -dl .* --color=auto'

# zsh
alias zshconfig="sudo vim ~/.zshrc"
alias ohmyzsh="sudo vim ~/.oh-my-zsh"

# reload
alias reload-zshrc="source ~/.zshrc && notify-send 'zshrc reloaded'"

# docker
alias d="docker "
alias dc="docker-compose "

# pacman 
alias p="sudo pacman "
