# sudo not required for some system commands
for x in mount umount sv pacman su ; do
	alias $x="sudo $x"
done

# useful
alias \
  s="sudo " \
	cp="cp -iv" \
	mv="mv -iv" \
	rm="rm -vI" \
  untar="tar -xzvf " \
  e="$EDITOR"

# commands
alias dotfiles="cd ~/dotfiles && $EDITOR"

# git
alias \
  g="git " \
  gs="git status" \
  ga="git add" \
  gc="git commit" \
  gp="git push" \

# directory
alias \
  cdd="cd ~/Desktop " \
  ls="exa" \
  ll="exa -la" \
  ll.='exa -dl .* --color=auto' \

# output information
alias \
  cat="bat"

# docker
alias \
  d="sudo docker " \
  dc="sudo docker-compose " \

# pacman 
alias p="sudo pacman "
