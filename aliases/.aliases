# sudo not required for some system commands
for x in mount umount sv pacman su ; do
	alias $x="sudo $x"
done

# useful
alias \
  s="sudo " \
  p="sudo pacman " \
	cp="cp -iv" \
	mv="mv -iv" \
  untar="tar -xzvf " \
  e="$EDITOR" \ 

# commands
alias dotfiles="cd ~/dotfiles && $EDITOR"

# rewrite standard commands
alias \
	rm="trash-put" \
  cat="bat" \ 

alias \
  ls="exa" \
  ll="exa -la" \
  ll.='exa -dl .* --color=auto' \

# git
alias \
  g="git " \
  gs="git status" \
  ga="git add" \
  gc="git commit" \
  gp="git push" \

# docker
alias \
  d="sudo docker " \
  dc="sudo docker-compose " \

