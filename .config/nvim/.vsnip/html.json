{
  "html5": {
    "prefix": ["html5", "!"],
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"${1:en}\">",
      "\t<head>",
      "\t\t<title>${2:My Title}</title>",
      "\t\t<meta charset=\"UTF-8\" />",
      "\t\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />",
      "\t\t<link href=\"${3:index.css}\" rel=\"stylesheet\" />",
      "\t</head>",
      "\t<body>",
      "\t\t$0",
      "\t</body>",
      "</html>"
    ],
    "description": "HTML - Defines a template for a html5 document"
  },
  "doctype": {
    "prefix": "doctype",
    "body": [
      "<!DOCTYPE>",
      "$1"
    ],
    "description": "HTML - Defines the document type",
    "scope": "text.html"
  }
}

