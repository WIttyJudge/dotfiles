{
  "local fucntion": {
    "prefix": "func_local",
    "body": [
      "local function ${1:name}()",
      "\t$0",
      "end"
    ],
    "description": "create local function"
  },
  "local variable": {
    "prefix": "var_local",
    "body": [
      "local ${1:variable} = $0"
    ],
    "description": "create local variable"
  },
  "create require setup": {
    "prefix": "require_setup",
    "body": [
      "require('${1:name}').setup($0)"
    ],
    "description": "create require setup"
  }
}

