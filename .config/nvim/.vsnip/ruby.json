{
  "class": {
    "prefix": ["class"],
    "body": [
      "class ${1:MyClass}",
      "\t$0",
      "end"
    ],
    "description": "Define class"
  },
  "class with inheritance": {
    "prefix": ["class<"],
    "body": [
      "class ${1:SubClass} < ${2:SuperClass}",
      "\t$0",
      "end"
    ],
    "description": "Define class with superclass"
  },
  "env": {
    "prefix": ["rails-env"],
    "body": [
      "<%= ENV['$1'] %>"
    ],
    "description": "Define class with superclass"
  },
  "rspec": {
    "prefix": "RSpec",
    "body": [
      "require 'rails_helper'",
      "",
      "RSpec.describe ${1:Name}, type: :${2:model} do",
      "\t$0",
      "end"
    ],
    "description": "rspec"
  },
  "if": {
    "prefix": "if",
    "body": "if ${1:statement}\n\t$0\nend",
    "description": "if block"
  },
  "def": {
    "prefix": "def",
    "body": "def ${1:name}\n\t$0\nend",
    "description": "def"
  },
	"case": {
		"prefix": "case",
		"body": [
			"case ${1:test}",
			"when $2",
			"\t$3",
			"when $4",
			"\t$5",
			"else",
			"\t$6",
			"end"
		]
	}
}
