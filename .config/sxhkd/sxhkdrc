/* Some environment variable are located in the .zpofile file. E.g. $TERMINAL */

/* start terminal */
super + Return
    $TERMINAL

/* start dmenu (a program launcher) */
super + p
  dmenu_run -x 450 -y 450 -z 500 -l 10

super + shift + r
      $TERMINAL -e btop

super + shift + w
      $TERMINAL -n calcurse -e calcurse

super + shift + q
      sysact

XF86Audio{Mute,LowerVolume,RaiseVolume}
    changevolume {mute, down, up}; pkill -RTMIN+10 dwmblocks 

/* Brightness volumes */
{XF86MonBrightnessDown, XF86MonBrightnessUp}
    changebrightness {down, up}; pkill -RTMIN+6 dwmblocks

/* PageDown button */
Next
    pactl set-source-mute @DEFAULT_SOURCE@ toggle; pkill -RTMIN+20 dwmblocks

/* screenshoter */
Print
    screentools

/* Custom commands */
Home
    dmenu-script-select

