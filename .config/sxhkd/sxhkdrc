/* Some environment variable are located in the .zpofile file. E.g. $TERMINAL */

/* start terminal */
super + Return
    $TERMINAL

/* start dmenu (a program launcher) */
super + p
    dmenu_run -c -l 10

super + shift + r
      $TERMINAL -e htop

super + shift + w
      $TERMINAL -n calcurse -e calcurse

super + shift + q
      system

XF86Audio{Mute,LowerVolume,RaiseVolume}
    pamixer --allow-boost {-t, -d 5, -i 5}; pkill -RTMIN+10 dwmblocks 

/* Brightness volumes */
{XF86MonBrightnessDown, XF86MonBrightnessUp}
    sudo light {-U 10, -A 10}; pkill -RTMIN+6 dwmblocks

/* PageDown button */
Next
    pactl set-source-mute @DEFAULT_SOURCE@ toggle; pkill -RTMIN+20 dwmblocks

/* screenshoter */
Print
    make-screenshot

/* Custom commands */
Home
    dmenu-script-select

