#!/usr/bin/env sh

function send_notification() {
  volume=$(pamixer --get-volume)
  dunstify -a "change-audio" -t 2000 -r 9993 -h int:value:"$volume" -i "$1" -u low "Volume: ${volume}%"
}

case $1 in
  volume-up)
    pamixer -u
    pamixer -i 5 --allow-boost
    send_notification $1
    ;;
  volume-down)
    pamixer -u
    pamixer -d 5 --allow-boost
    send_notification $1
    ;;
  volume-toggle)
    pamixer -t
    if $(pamixer --get-mute); then
      dunstify -a "change-audio" -t 2000 -r 9993 -i volume-mute -u low "Muted"
    else
      send_notification volume-up
    fi
    ;;
  microphone-toggle)
    pactl set-source-mute @DEFAULT_SOURCE@ toggle

    index=$(pamixer --list-sources | grep input | awk '{print $1}')
    mic_muted="$(pamixer --source "$index" --get-mute)"
    [ "$mic_muted" == "true" ] &&
      dunstify -a "change-audio" -t 2000 -r 9992 -i "microphone-mute" "Muted" ||
      dunstify -a "change-audio" -t 2000 -r 9992 -i "microphone" "Active"
    ;;
  *)
    echo >&2 "Unknown action '$1'"
    exit 1
    ;;
esac
