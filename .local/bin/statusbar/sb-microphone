#!/bin/sh

case $BLOCK_BUTTON in
  1) change-audio microphone-toggle; pkill -RTMIN+20 dwmblocks ;;
esac

show_status() {
  pamixer --list-sources \
    | grep input \
    | awk '{print $1}' \
    | while read -r index; do

      mic_muted="$(pamixer --source "$index" --get-mute)"

      [ "$mic_muted" = "true" ] && echo 'muted' || echo 'unmuted'
  done
}

mic_muted="$(show_status)"

if [ "$mic_muted" = "muted" ]; then
  icon="🔇"
else
  icon="🎙️"
fi

echo $icon
