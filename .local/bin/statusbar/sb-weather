#!/bin/bash

weatherreport="${XDG_CACHE_HOME:-$HOME/.cache}/weather-report"
LOCATION=Moscow,Dnipro,Tbilisy

get_weather() {
  curl -sf "wttr.in/{$LOCATION}?format=%l:+%c+%t+%h\n" >"$weatherreport"
  notify-send 'Weather Updated'
  exit 1
}

show_weather() {
  weather=$(cat $weatherreport)

  notify-send 'Weather Report' "$weather"
  exit 1
}

icon="⛅"

case $BLOCK_BUTTON in
  1) show_weather ;;
  2) get_weather ;;
	3) notify-send "🌈 Weather module" "\- Left click for full forecast.
- Middle click to update forecast.
☔: Chance of rain/snow
🥶: Daily low
🌞: Daily high" ;;
esac

printf "%s" "$icon"
