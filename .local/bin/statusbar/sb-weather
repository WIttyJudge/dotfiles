#!/bin/bash

weatherreport="${XDG_CACHE_HOME:-$HOME/.cache}/weather-report"
LOCATION=Moscow,Dnipro,Tbilisy

get_weather() {
  curl -sf "wttr.in/{$LOCATION}?format=%l:+%c+%t+%h\n" >"$weatherreport"
  notify-send 'Weather Updated'
  exit 1
}

show_weather() {
  weather=$(< $weatherreport)

  notify-send 'Weather Report' "$weather"
  exit 1
}

icon="⛅"

printf "%s" "$icon"
