#!/bin/sh

uptime=$(uptime -p | sed -e 's/up //g')

poweroff=" Poweroff"
reboot=" Reboot"
suspend=" Suspend"
lock=" Lock"
logout=" Logout"
cancel=" Cancel"

option="$cancel\n$poweroff\n$reboot\n$suspend\n$lock\n$logout"

select="$(echo -e "$option" | rofi -dmenu -theme theme/dmenu)"

case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

case $select in
	$poweroff)
		$ctl poweroff -i
		;;
	$reboot)
		$ctl reboot -i
		;;
	$suspend)
		slock $ctl suspend
		;;
	$lock)
		slock
		;;
	$logout)
		# kill -TERM dwmpid $(pidof dwm)
		bspc quit
    ;;
  *)
    exit 1
    ;;
esac

