#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
  selected=$1
else
  selected=$(find ~/projects ~/projects/clusters ~/projects/repos ~/projects/ansible -mindepth 1 -maxdepth 1 -type d | fzf --height=100% --no-border)
fi

selected_name=$(basename "$selected" | tr . _)

# operation cancelled by user
[ -z $selected ] && exit 0

# Checks if tmux session is not opened
not_in_tmux() {
  [ -z "$TMUX" ]
}

# Checks if selected session have already created
session_exists() {
  tmux has-session -t $selected_name 2>/dev/null
}

create_if_needed_and_attach() {
  # Create the session and attach it automatically.
  if not_in_tmux; then
    tmux new-session -A -s $selected_name -c $selected
    exit 0
  fi

  if ! session_exists; then
    tmux new-session -ds $selected_name -c $selected
  fi

  tmux switch-client -t $selected_name
}

create_if_needed_and_attach
