#!/bin/sh

commands=(
  '< Exit'
  '---'
  '1 [ System ]'
  '2 [ Reloader ]'
  '---'
  'dotfiles'
  'suckess-tools'
)

scripts_folder="$HOME/.local/bin/dmenu"

# choice="$(printf '%b\n' "${commands[@]}" | rofi -dmenu -i bmenu -p "Select command > ")"
choice="$(printf '%b\n' "${commands[@]}" | dmenu -x 450 -y 450 -z 500 -l 10)"



case "$choice" in
  "1 [ System ]")
    sysact ;;
  "2 [ Reloader ]")
    dmenu-reloader ;;
  "dotfiles")
    $TERMINAL -e sh -c 'tmux-sessionizer /home/wittyjudge/dotfiles' ;;
  "suckess-tools")
    $TERMINAL -e sh -c 'tmux-sessionizer /home/wittyjudge/suckless-tools' ;;
  '< Exit') exit ;;
  *) exit ;;
esac
