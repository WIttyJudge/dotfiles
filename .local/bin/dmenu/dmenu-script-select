#!/bin/sh

commands=(
  '< Exit'
  '1 [ System ]'
  '2 [ Reloader ]'
  'dotfiles'
  'suckess-tools'
)

choice="$(printf '%b\n' "${commands[@]}" | rofi -dmenu -theme theme/dmenu)"

case "$choice" in
  "1 [ System ]")
    sysact ;;
  "2 [ Reloader ]")
    dmenu-reloader ;;
  "dotfiles")
    $TERMINAL -e sh -c 'tmux-sessionizer /home/wittyjudge/dotfiles' ;;
  "suckess-tools")
    $TERMINAL -e sh -c 'tmux-sessionizer /home/wittyjudge/suckless-tools' ;;
  '< Exit') exit ;;
  *) exit ;;
esac
