#!/bin/sh

files=(
  # i3wm
  .Xresources
  sxhkd
  .zshrc
  # dwm
  bspwm
)

choice="$(printf '%s\n' "${files[@]}" | rofi -dmenu -theme theme/dmenu)"

notifier() {
  notify-send 'Reloader' "$1 successfully reloaded."
}

case "$choice" in
  # i3wm)
  #   i3-msg restart && notifier "i3wm" ;;
  .Xresources)
    xrdb ~/.Xresources && notifier ".Xresources" ;;
  .zshrc)
    source ~/.zshrc && notifier ".zshrc" ;;
  sxhkd)
    pkill -USR1 -x sxhkd
    notifier "sxhkd" ;;
  # dwm)
  #   kill -HUP $(pgrep -u $USER "\bdwm$") &&
    # notifier "dwm" ;;
  bspwm)
    bspc wm -r 
    notifier "Bspwm" ;;
  *) exit ;;
esac

