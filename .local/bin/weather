#!/usr/bin/env sh

weatherreport="${XDG_CACHE_HOME:-$HOME/.cache}/weather-report"

LOCATION=Moscow,Dnipro,Paphos

get() {
  curl -sf "wttr.in/{$LOCATION}?format=%l:+%c+%t+%h\n" >"$weatherreport"
  notify-send 'Weather Updated'
  exit 1
}

show() {
  curl -sf "wttr.in/{$LOCATION}?T" | yad --text-info --maximized
  exit 1
}

case $1 in
  get) get ;;
  show) show ;;
  *) 
    echo >&2 "Unknown action '$1'"
    exit 1
    ;;
esac

