#!/bin/bash

function send_notification() {
	brightness=$(printf "%.0f\n" $(light))
	dunstify -a "changebrightness" -u low -r 9991 -h int:value:"$brightness" -i "sun-solid" "Brightness: $brightness%" -t 2000
}

case $1 in
up)
  sudo light -A 10
	send_notification $1
	;;
down)
  sudo light -U 10
	send_notification $1
	;;
esac
