#!/bin/bash

command="pamixer"

ifcommand $command || exit

function send_notification() {
	volume=$($command --get-volume)
	dunstify -a "changevolume" -u low -r "9993" -h int:value:"$volume" -i "volume-$1" "Volume: ${volume}%" -t 2000
}

case $1 in
  up)
    $command -u
    $command -i 5 --allow-boost
    send_notification $1
    ;;
  down)
    $command -u
    $command -d 5 --allow-boost
    send_notification $1
    ;;
  mute)
    $command -t
    if $($command --get-mute); then
      dunstify -i volume-mute -a "changevolume" -t 2000 -r 9993 -u low "Muted"
    else
      send_notification up
    fi
    ;;
esac
